PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# MercadoPago
MP_ACCESS_TOKEN=your-mp-access-token
MP_PUBLIC_KEY=your-mp-public-key
MP_WEBHOOK_SECRET=your-mp-webhook-secret

# Frontend URL (for MP redirects and CORS)
FRONTEND_URL=http://localhost:5173

# n8n Webhook
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/matmasterroll

# Backend public URL (for MP webhook callback)
BACKEND_URL=http://localhost:3001
